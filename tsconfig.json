{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "baseUrl": "./src",
    "paths": {
      "@api/*": ["api/*"],
      "@app/*": ["app/*"],
      "@features/*": ["features/*"],
      "@hooks/*": ["hooks/*"],
      "@services/*": ["services/*"],
      "@storage/*": ["storage/*"],
      "@constants/*": ["constants/*"],
      "@appTypes/*": ["types/*"],
      "@screens/*": ["screens/*"],
      "@navigation/*": ["navigation/*"],
      "@svg": ["assets/svg/index"],
      "@svg/*": ["assets/svg/*"],
      "@png": ["assets/png/index"],
      "@png/*": ["assets/png/*"],
      "@components/*": ["components/*"],
      "@utils/*": ["utils/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
